+!*************************SUBROUTINE OUTPOT_Z **************************
+!   write planar-averaged potential along z to a specified unit
+!   This is used in IBRION=24 i-PI driver mode to produce a compact
+!   LOCPOT_Z file from the real-space potential CVTOT without writing
+!   the full 3D LOCPOT.
+!***********************************************************************
+
+      SUBROUTINE OUTPOT_Z(GRIDC, LATT_CUR, IU, CVTOT)
+      USE prec
+      USE mgrid
+      USE lattice
+      IMPLICIT REAL(q) (A-H,O-Z)
+
+      TYPE (grid_3d) GRIDC
+      TYPE (latt)    LATT_CUR
+      RGRID CVTOT(GRIDC%RL%NP)
+! local variables
+      INTEGER :: NZ, NALLOC, N
+      REAL(q), ALLOCATABLE :: WORK(:)
+      REAL(q) :: SUMPLANE, AVGVAL
+      REAL(q) :: LZ, DZ, ZPOS
+      INTEGER :: ISTAT
+
+      NALLOC = GRIDC%NGX*GRIDC%NGY
+      ALLOCATE(WORK(NALLOC), STAT=ISTAT)
+      IF (ISTAT>0) RETURN
+
+!     length of third lattice vector (Angstrom)
+      LZ = SQRT( LATT_CUR%A(1,3)*LATT_CUR%A(1,3) &
+     &         + LATT_CUR%A(2,3)*LATT_CUR%A(2,3) &
+     &         + LATT_CUR%A(3,3)*LATT_CUR%A(3,3) )
+
+      IF (GRIDC%NGZ.GT.1) THEN
+         DZ = LZ / REAL(GRIDC%NGZ-1, q)
+      ELSE
+         DZ = 0._q
+      ENDIF
+
+      WRITE(IU,'(A)') '# z(Angstrom)  V_avg(eV)'
+
+      DO NZ = 1, GRIDC%NGZ
+         CALL MRG_GRID_RL_PLANE(GRIDC, WORK, CVTOT, NZ)
+         SUMPLANE = 0._q
+         DO N = 1, NALLOC
+            SUMPLANE = SUMPLANE + WORK(N)
+         ENDDO
+         AVGVAL = SUMPLANE / REAL(NALLOC, q)
+         ZPOS   = REAL(NZ-1, q) * DZ
+         WRITE(IU,'(2E20.12)') ZPOS, AVGVAL
+      ENDDO
+
+      DEALLOCATE(WORK)
+
+      RETURN
+      END SUBROUTINE
+
+
+
+      SUBROUTINE VACUUM_LEVEL_FROM_CVTOT(GRIDC, LATT_CUR, CVTOT, Z_MIN_A, Z_MAX_A, VAC_LEVEL_EV)
+      USE prec
+      USE mgrid
+      USE lattice
+      IMPLICIT REAL(q) (A-H,O-Z)
+
+      TYPE (grid_3d) GRIDC
+      TYPE (latt)    LATT_CUR
+      RGRID CVTOT(GRIDC%RL%NP)
+      REAL(q) :: Z_MIN_A, Z_MAX_A
+      REAL(q) :: VAC_LEVEL_EV
+      INTEGER :: NZ, NALLOC, N
+      REAL(q), ALLOCATABLE :: WORK(:)
+      REAL(q) :: SUMPLANE, AVGVAL
+      REAL(q) :: LZ, DZ, ZPOS
+      REAL(q) :: SUM_IN_REGION
+      INTEGER :: N_IN, ISTAT
+
+      NALLOC = GRIDC%NGX*GRIDC%NGY
+      ALLOCATE(WORK(NALLOC), STAT=ISTAT)
+      IF (ISTAT>0) THEN
+         VAC_LEVEL_EV = 0._q
+         RETURN
+      ENDIF
+
+      LZ = SQRT( LATT_CUR%A(1,3)*LATT_CUR%A(1,3) &
+     &         + LATT_CUR%A(2,3)*LATT_CUR%A(2,3) &
+     &         + LATT_CUR%A(3,3)*LATT_CUR%A(3,3) )
+
+      IF (GRIDC%NGZ.GT.1) THEN
+         DZ = LZ / REAL(GRIDC%NGZ-1, q)
+      ELSE
+         DZ = 0._q
+      ENDIF
+
+      SUM_IN_REGION = 0._q
+      N_IN = 0
+
+      DO NZ = 1, GRIDC%NGZ
+         CALL MRG_GRID_RL_PLANE(GRIDC, WORK, CVTOT, NZ)
+         SUMPLANE = 0._q
+         DO N = 1, NALLOC
+            SUMPLANE = SUMPLANE + WORK(N)
+         ENDDO
+         AVGVAL = SUMPLANE / REAL(NALLOC, q)
+         ZPOS   = REAL(NZ-1, q) * DZ
+         IF (ZPOS.GE.Z_MIN_A .AND. ZPOS.LE.Z_MAX_A) THEN
+            SUM_IN_REGION = SUM_IN_REGION + AVGVAL
+            N_IN = N_IN + 1
+         ENDIF
+      ENDDO
+
+      IF (N_IN>0) THEN
+         VAC_LEVEL_EV = SUM_IN_REGION / REAL(N_IN, q)
+      ELSE
+         VAC_LEVEL_EV = 0._q
+      ENDIF
+
+      DEALLOCATE(WORK)
+
+      RETURN
+      END SUBROUTINE
+
 
