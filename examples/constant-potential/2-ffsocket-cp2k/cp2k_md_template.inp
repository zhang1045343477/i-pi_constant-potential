# CP2K Input Template for Constant Potential MD with i-PI
# Template substitutions: {{CHARGE}}, {{HOST}}, {{PORT}}

&GLOBAL
  PROJECT 36Al_constant_potential_q{{CHARGE}}
  RUN_TYPE DRIVER
  PRINT_LEVEL LOW
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  STRESS_TENSOR ANALYTICAL

  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE {{CHARGE}}

    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
      NGRIDS 5
    &END MGRID

    &QS
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION PS
      EXTRAPOLATION_ORDER 3
    &END QS

    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 5.0E-06
      MAX_SCF 400
      ADDED_MOS 30

      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300
      &END SMEAR

      &MIXING T
        METHOD BROYDEN_MIXING
        ALPHA 0.4
        NBROYDEN 8
      &END MIXING

      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC

    &PRINT
      &E_DENSITY_CUBE OFF
      &END E_DENSITY_CUBE
      &EFIELD_CUBE OFF
      &END EFIELD_CUBE
    &END PRINT
  &END DFT

  &SUBSYS
    &CELL
      # Will be set by i-PI
      A 9.9204 0.0 0.0
      B 0.0 8.5913 0.0
      C 0.0 0.0 20.0
      PERIODIC XYZ
    &END CELL

    &TOPOLOGY
      COORD_FILE_NAME 36Al_REV.xyz
      COORD_FILE_FORMAT XYZ
    &END TOPOLOGY

    &KIND Al
      ELEMENT Al
      BASIS_SET DZVP-MOLOPT-SR-GTH-q3
      POTENTIAL GTH-PBE
    &END KIND
  &END SUBSYS
&END FORCE_EVAL

# i-PI Driver Settings
&MOTION
  &DRIVER
    HOST {{HOST}}
    PORT {{PORT}}
  &END DRIVER

&END MOTION